{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["svelte"]
  },
  "include": ["src/**/*", "vite.config.ts"]
}
